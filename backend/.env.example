# Copy this file to .env and fill in your Supabase credentials
# Get them from: Supabase Dashboard → Settings → API

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Backend host/port
HOST=127.0.0.1
PORT=8000

# GitHub Personal Access Token (optional – raises rate limit from 60 → 5000/hr)
# Generate at: https://github.com/settings/tokens
GITHUB_PAT=

# Google Gemini API key (required for AI analysis + JD extraction)
# Generate at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
